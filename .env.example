# ============================================
# OmniData — Environment Variables
# Copy this to .env and fill in real values
# ============================================

# Groq — 3 keys rotated per-request for rate-limit resilience
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxx

# Pinecone — Vector database for RAG + Salesforce + Self-Healing SQL
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxx
PINECONE_HYBRID_INDEX=omnidata-hybrid
PINECONE_DENSE_INDEX=omnidata-dense

# Snowflake — Data warehouse
SNOWFLAKE_ACCOUNT=xxxxxxx.region.gcp
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=OMNIDATA_DB

# E2B — Secure sandbox for AI-generated visualization code
E2B_API_KEY=e2b_xxxxxxxxxxxxxxxxxxxx

# Tavily — Live web search for market intelligence
TAVILY_API_KEY=tvly_xxxxxxxxxxxxxxxxxxxx

# Salesforce — CRM data (optional, gracefully skipped if empty)
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_INSTANCE_URL=

# Confluence — Knowledge base (optional, uses Pinecone vectors)
CONFLUENCE_BASE_URL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_USER_EMAIL=
CONFLUENCE_DEFAULT_SPACE=AURA

# App
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
